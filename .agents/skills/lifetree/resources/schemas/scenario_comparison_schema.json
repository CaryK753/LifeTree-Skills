{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LifeTreeScenarioComparisonSchema",
  "description": "Schema for multi-pathway trade-off matrices and comparative evaluations",
  "type": "object",
  "required": ["comparison_summary", "comparison_matrix"],
  "properties": {
    "comparison_summary": {
      "type": "object",
      "required": ["pathways_compared_count", "top_recommended_pathway", "highest_composite_score"],
      "properties": {
        "pathways_compared_count": { "type": "integer" },
        "top_recommended_pathway": { "type": "string" },
        "highest_composite_score": { "type": "number" }
      }
    },
    "comparison_matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["pathway_name", "financial_cost_usd", "horizon_months", "risk_level", "composite_tradeoff_score"],
        "properties": {
          "pathway_name": { "type": "string" },
          "financial_cost_usd": { "type": "number" },
          "horizon_months": { "type": "number" },
          "risk_level": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
          "prerequisite_friction": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
          "plan_b_reliability_score": { "type": "number" },
          "composite_tradeoff_score": { "type": "number" }
        }
      }
    }
  }
}
